import numpy as np
import matplotlib.pyplot as plt

# Angle values
theta = np.linspace(0, 2*np.pi, 360)

# Array factor for 3-element broadside array (d = lambda/2)
AF = 1 + 2 * np.cos(np.pi * np.cos(theta))

# Normalize
AF = np.abs(AF)
AF = AF / np.max(AF)

# Plot in polar form
plt.figure()
ax = plt.subplot(111, polar=True)

ax.plot(theta, AF)

ax.set_title("2D Radiation Pattern of 3-Element Broadside Array")

plt.show()


import numpy as np
import matplotlib.pyplot as plt

# Parameters
lam = 1
d = lam / 2
k = 2 * np.pi / lam
N = 3   # number of elements (changed)

# Angle range
theta = np.linspace(0, np.pi, 1000)

# Array Factor (General Form)
AF = np.zeros_like(theta, dtype=complex)

for n in range(N):
    AF += np.exp(1j * n * k * d * np.cos(theta))

# Normalize
AF_mag = np.abs(AF)
AF_mag = AF_mag / np.max(AF_mag)

# Plot
plt.figure(figsize=(6,6))
ax = plt.subplot(111, projection='polar')
ax.plot(theta, AF_mag)
ax.set_title("2D Radiation Pattern (3-Element Broadside Array)\n")
plt.show()
